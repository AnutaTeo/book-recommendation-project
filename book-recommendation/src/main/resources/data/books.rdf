<?xml version="1.0" encoding="UTF-8"?>

<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:ex="http://example.org/book-recommendation#">

    <ex:User rdf:about="http://example.org/book-recommendation#Alice">
        <ex:hasReadingLevel>Intermediate</ex:hasReadingLevel>
        <ex:prefersTheme>Science Fiction</ex:prefersTheme>
    </ex:User>

    <ex:User rdf:about="http://example.org/book-recommendation#Bob">
        <ex:hasReadingLevel>Beginner</ex:hasReadingLevel>
        <ex:prefersTheme>Mystery</ex:prefersTheme>
    </ex:User>



    <ex:Book rdf:about="http://example.org/book-recommendation#Dune">
        <ex:title>Dune</ex:title>
        <ex:hasTheme>Science Fiction</ex:hasTheme>
        <ex:hasTheme>Fantasy</ex:hasTheme>
        <ex:suitableForReadingLevel>Advanced</ex:suitableForReadingLevel>
    </ex:Book>

    <ex:Book rdf:about="http://example.org/book-recommendation#TheSilentPatient">
        <ex:title>The Silent Patient</ex:title>
        <ex:hasTheme>Mystery</ex:hasTheme>
        <ex:hasTheme>Murder</ex:hasTheme>
        <ex:suitableForReadingLevel>Intermediate</ex:suitableForReadingLevel>
    </ex:Book>

    <ex:Book rdf:about="http://example.org/book-recommendation#HungerGames">
        <ex:title>Hunger Games</ex:title>
        <ex:hasTheme>Science Fiction</ex:hasTheme>
        <ex:hasTheme>Fantasy</ex:hasTheme>
        <ex:suitableForReadingLevel>Beginner</ex:suitableForReadingLevel>
    </ex:Book>


    <ex:RecommendationRule rdf:about="http://example.org/book-recommendation#RecommendedBookRule">
        <ex:description>
            A book is recommended for a user if it belongs to the user's preferred theme and matches the user's reading level.
        </ex:description>
    </ex:RecommendationRule>

</rdf:RDF>